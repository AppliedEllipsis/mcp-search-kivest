{
  "name": "@kivest/mcp-search",
  "version": "1.0.1",
  "description": "MCP server for Kivest AI Search with intelligent rate limiting and request queuing",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "mcp-search-kivest": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "node dist/test.js",
    "test:comprehensive": "node dist/comprehensive-test.js",
    "test:stress": "node dist/stress-test.js",
    "lint": "eslint src/**/*.ts",
    "prepare": "npm run build"
